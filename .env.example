# Environment Configuration
# Copy to .env and fill in your values

# Twitter/X Authentication (optional - for rate limits)
TWITTER_SCANNER_TWITTER__USERNAME=
TWITTER_SCANNER_TWITTER__PASSWORD=
TWITTER_SCANNER_TWITTER__EMAIL=

# Database - PostgreSQL
TWITTER_SCANNER_DATABASE__POSTGRES_HOST=localhost
TWITTER_SCANNER_DATABASE__POSTGRES_PORT=5432
TWITTER_SCANNER_DATABASE__POSTGRES_DB=twitter_scanner
TWITTER_SCANNER_DATABASE__POSTGRES_USER=postgres
TWITTER_SCANNER_DATABASE__POSTGRES_PASSWORD=

# Database - ChromaDB (vector storage)
TWITTER_SCANNER_DATABASE__CHROMA_PERSIST_DIR=./data/chroma_db

# AI/LLM Configuration
TWITTER_SCANNER_AI__PROVIDER=openai  # openai, ollama, groq
TWITTER_SCANNER_AI__MODEL=gpt-4o-mini
TWITTER_SCANNER_AI__API_KEY=
TWITTER_SCANNER_AI__BASE_URL=  # For Ollama: http://localhost:11434/v1

# Proxy Configuration (optional)
TWITTER_SCANNER_PROXY__ENABLED=false
TWITTER_SCANNER_PROXY__API_KEY=
TWITTER_SCANNER_PROXY__PROXY_URL=

# Alert Configuration
TWITTER_SCANNER_ALERT__TELEGRAM_BOT_TOKEN=
TWITTER_SCANNER_ALERT__TELEGRAM_CHAT_ID=
TWITTER_SCANNER_ALERT__DISCORD_WEBHOOK_URL=

# Scanner Behavior
TWITTER_SCANNER_SCANNER__HEADLESS=true
TWITTER_SCANNER_SCANNER__MIN_DELAY=2.0
TWITTER_SCANNER_SCANNER__MAX_DELAY=5.0
TWITTER_SCANNER_SCANNER__STEALTH_ENABLED=true